---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppCard from '../components/AppCard.astro';
import AppModal from '../components/AppModal.astro';
import Badge from '../components/Badge.astro';

const apps = [
	{
		title: "Semana-Treino",
		slug: "semana-treino",
		description: "Treino semanal sem complicação.",
		accent: "#22c55e",
		tags: ["localStorage", "Sem cadastro", "Rápido"],
		features: [
			"Lista de exercícios personalizada",
			"Limpar semana com um clique",
			"Configurações intuitivas",
			"Funciona 100% offline",
			"Privacidade total dos dados",
			"Interface minimalista"
		],
		appUrl: "https://ptcmariano.github.io/semana-treino/",
		githubUrl: "https://github.com/ptcmariano/semana-treino"
	},
	{
		title: "Próximo Ônibus",
		slug: "proximo-onibus-inter",
		description: "Quanto tempo falta pro meu ônibus?",
		accent: "#3b82f6",
		tags: ["localStorage", "Sem cadastro", "Interface limpa"],
		features: [
			"Favoritar linhas de ida e volta",
			"Horários do dia sempre visíveis",
			"Cálculo automático de tempo restante",
			"Sem necessidade de GPS",
			"Foco em mobilidade urbana",
			"Leve e instantâneo"
		],
		appUrl: "https://ptcmariano.github.io/proximo-onibus-inter/",
		githubUrl: "https://github.com/ptcmariano/proximo-onibus-inter"
	},
	{
		title: "PokéVidas",
		slug: "pokevidas",
		description: "Prêmios e dano no Pokémon TCG, sem papel.",
		accent: "#a855f7",
		tags: ["localStorage", "Sem cadastro", "Feito pra torneios"],
		features: [
			"Contador de prêmios e dano",
			"Histórico de partidas local",
			"Exportar log em texto",
			"Ideal para jogadores competitivos",
			"Bateria amigável",
			"Design otimizado para torneios"
		],
		appUrl: "https://ptcmariano.github.io/pokevidas/",
		githubUrl: "https://github.com/ptcmariano/pokevidas"
	}
];
---

<BaseLayout title="Mini Apps | Simples e Instantâneos" description="Micro-aplicativos focados em simplicidade, velocidade e privacidade. Sem cadastro, seus dados ficam no seu dispositivo.">
	<main>
		<!-- Hero Section -->
		<section id="hero" class="hero stack gap-8">
			<div class="hero-content wrapper stack gap-4">
				<div class="badges">
					<Badge text="LocalStorage" />
					<Badge text="Mobile-first" />
					<Badge text="Leve" />
				</div>
				<h1>Mini Apps que resolvem problemas reais.</h1>
				<p class="tagline">Sem cadastro. Sem enrolação. Rápidos no celular.</p>
				<div class="hero-cta">
					<a href="#apps" class="btn-primary">Ver Aplicativos</a>
				</div>
			</div>
		</section>

		<!-- Apps Section -->
		<section id="apps" class="apps wrapper stack gap-12">
			<div class="section-header">
				<h2>Apps Desenvolvidos</h2>
				<p>Ferramentas diretas criadas para facilitar o seu dia a dia.</p>
			</div>
			
			<div class="grid">
				{apps.map(app => (
					<AppCard {...app} />
				))}
			</div>
		</section>

		<!-- Why Section -->
		<section id="sobre" class="why wrapper">
			<div class="why-container">
				<h2>Por que Mini Apps?</h2>
				<div class="features-grid">
					<div class="feature">
						<div class="icon">🔓</div>
						<h3>Sem cadastro</h3>
						<p>Não pedimos seu e-mail nem sua senha. É só abrir e começar a usar imediatamente.</p>
					</div>
					<div class="feature">
						<div class="icon">💾</div>
						<h3>Dados locais</h3>
						<p>Tudo o que você salva fica guardado no seu dispositivo via <code>localStorage</code>.</p>
					</div>
					<div class="feature">
						<div class="icon">⚡</div>
						<h3>Leves e rápidos</h3>
						<p>Foco total no essencial. Sem bibliotecas pesadas, sem rastreamento invasivo.</p>
					</div>
					<div class="feature">
						<div class="icon">❤️</div>
						<h3>Propósito</h3>
						<p>Feitos com carinho (e um pouco de ódio de ter que preencher formulários inúteis).</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Coming Soon Section -->
		<section id="em-breve" class="coming-soon wrapper stack gap-8">
			<h2>Em breve</h2>
			<div class="grid">
				<div class="card placeholder">
					<div class="content">
						<h3>Em desenvolvimento...</h3>
						<p>Novas ideias saindo do forno para simplificar sua vida.</p>
					</div>
				</div>
				<div class="card suggestion">
					<div class="content">
						<h3>Sugira um mini app</h3>
						<p>Tem uma ideia de micro-app? Fala comigo!</p>
						<a href="https://wa.me/5515" class="btn-whatsapp">Me chama no WhatsApp</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<!-- Modals -->
	{apps.map(app => (
		<AppModal {...app} />
	))}

	<script>
		// Handle Modals
		const modalButtons = document.querySelectorAll('.btn-details');
		const closeButtons = document.querySelectorAll('.close-modal');
		const dialogs = document.querySelectorAll('dialog');

		modalButtons.forEach(btn => {
			btn.addEventListener('click', (e) => {
				e.stopPropagation();
				const slug = (btn as HTMLElement).dataset.slug;
				const modal = document.querySelector(`#modal-${slug}`) as HTMLDialogElement;
				if (modal) modal.showModal();
			});
		});

		// Close modal on click outside
		dialogs.forEach(dialog => {
			dialog.addEventListener('click', (e) => {
				const rect = dialog.getBoundingClientRect();
				const isInDialog = (rect.top <= e.clientY && e.clientY <= rect.top + rect.height &&
					rect.left <= e.clientX && e.clientX <= rect.left + rect.width);
				if (!isInDialog) {
					dialog.close();
				}
			});
		});

		closeButtons.forEach(btn => {
			btn.addEventListener('click', () => {
				const modal = btn.closest('dialog');
				if (modal) modal.close();
			});
		});

		// Handle Share API
		const shareButtons = document.querySelectorAll('.share-btn');
		shareButtons.forEach(btn => {
			btn.addEventListener('click', async () => {
				const title = (btn as HTMLElement).dataset.title;
				const url = (btn as HTMLElement).dataset.url;
				
				if (navigator.share) {
					try {
						await navigator.share({
							title: title,
							text: `Confira este mini app: ${title}`,
							url: url
						});
					} catch (err) {
						console.log('Share failed', err);
					}
				} else {
					// Fallback to clipboard
					try {
						await navigator.clipboard.writeText(url!);
						(btn as HTMLElement).innerText = 'Copiado!';
						setTimeout(() => {
							(btn as HTMLElement).innerText = 'Compartilhar';
						}, 2000);
					} catch (err) {
						console.error('Clipboard failed', err);
					}
				}
			});
		});
	</script>
</BaseLayout>

<style>
	main {
		display: flex;
		flex-direction: column;
		gap: 8rem;
		padding-bottom: 8rem;
	}

	/* Hero Section */
	.hero {
		min-height: 90vh;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		background: 
            radial-gradient(circle at 20% 30%, rgba(34, 197, 94, 0.05) 0%, transparent 50%),
            radial-gradient(circle at 80% 70%, rgba(168, 85, 247, 0.05) 0%, transparent 50%);
		padding-top: 4rem;
        position: relative;
	}

    .hero::after {
        content: '';
        position: absolute;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle at center, rgba(59, 130, 246, 0.03) 0%, transparent 70%);
        pointer-events: none;
    }

	.badges {
		display: flex;
		justify-content: center;
		gap: 0.5rem;
        animation: fadeInDown 0.8s ease-out;
	}

	h1 {
		font-size: clamp(3rem, 10vw, 5rem);
		line-height: 1.05;
		background: linear-gradient(to bottom, #fff 30%, #a1a1aa);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
        font-weight: 800;
        letter-spacing: -0.02em;
        animation: fadeInUp 1s ease-out 0.2s both;
	}

	.tagline {
		font-size: var(--text-xl);
		color: var(--gray-300);
		max-width: 45ch;
		margin-inline: auto;
        animation: fadeInUp 1s ease-out 0.4s both;
	}

    .hero-cta {
        animation: fadeInUp 1s ease-out 0.6s both;
    }

	.btn-primary {
		display: inline-block;
		background: #fff;
		color: #000;
		padding: 1.25rem 3rem;
		border-radius: 9999px;
		font-weight: 700;
		text-decoration: none;
		transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        box-shadow: 0 0 20px rgba(255, 255, 255, 0.1);
	}

	.btn-primary:hover {
		transform: translateY(-4px) scale(1.05);
		box-shadow: 0 20px 40px -10px rgba(255, 255, 255, 0.3);
	}

	/* Common Grid */
	.grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
	}

	@media (min-width: 768px) {
		.grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	/* Section Headers */
	.section-header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.section-header h2 {
		font-size: var(--text-5xl);
		color: var(--gray-0);
		margin-bottom: 1.5rem;
        letter-spacing: -0.01em;
	}

	.section-header p {
		font-size: var(--text-lg);
		color: var(--gray-400);
        max-width: 50ch;
        margin-inline: auto;
	}

	/* Why Section */
	.why {
		padding: 6rem 2rem;
		background: linear-gradient(180deg, var(--gray-900), var(--gray-950));
		border-radius: 3rem;
		border: 1px solid var(--gray-800);
        position: relative;
        overflow: hidden;
	}

    .why::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle at center, rgba(59, 130, 246, 0.02) 0%, transparent 50%);
        pointer-events: none;
    }

	.why h2 {
		text-align: center;
		margin-bottom: 5.5rem;
		font-size: var(--text-4xl);
		color: var(--gray-0);
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 4rem;
	}

	.feature {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
        background: rgba(255, 255, 255, 0.02);
        padding: 2.5rem;
        border-radius: 2rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: transform 0.3s ease, background 0.3s ease;
	}

    .feature:hover {
        transform: translateY(-5px);
        background: rgba(255, 255, 255, 0.04);
        border-color: rgba(255, 255, 255, 0.1);
    }

	.feature .icon {
		font-size: 3rem;
	}

	.feature h3 {
		font-size: var(--text-2xl);
		color: var(--gray-0);
	}

	.feature p {
		color: var(--gray-400);
		line-height: 1.7;
        font-size: var(--text-base);
	}

	/* Coming Soon */
	.coming-soon h2 {
		font-size: var(--text-4xl);
		color: var(--gray-0);
		text-align: center;
	}

	.card.placeholder, .card.suggestion {
		background: var(--gray-900);
		border: 1px dashed var(--gray-600);
		border-radius: 2rem;
		padding: 3rem;
		text-align: center;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 2rem;
        transition: border-color 0.3s ease;
	}

    .card.placeholder:hover {
        border-color: var(--gray-400);
    }

	.card.suggestion {
		border-style: solid;
		background: linear-gradient(135deg, var(--gray-900), var(--gray-950));
        border-color: var(--gray-800);
	}

    .card.suggestion:hover {
        border-color: var(--accent-green);
    }

	.btn-whatsapp {
		color: var(--accent-green);
		text-decoration: none;
		font-weight: 700;
        font-size: var(--text-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
	}

    .btn-whatsapp:hover {
        text-decoration: underline;
    }

    /* Animations */
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
