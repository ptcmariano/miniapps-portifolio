---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página Não Encontrada | Paulinho.apps" description="Erro 404 — esta página não foi encontrada">
	<main class="wrapper error-page">
		<div class="content">
			<h1>404</h1>
			<p>Opa! Parece que você se perdeu no caminho.</p>
			<a href="/" class="btn-primary">Voltar para a Home</a>
		</div>
	</main>
</BaseLayout>

<style>
	.error-page {
		min-height: 70vh;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
	}

	.content {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		align-items: center;
	}

	h1 {
		font-size: 8rem;
		background: var(--gradient-accent);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		line-height: 1;
	}

	p {
		font-size: var(--text-xl);
		color: var(--gray-300);
	}

	.btn-primary {
		display: inline-block;
		background: var(--gray-0);
		color: var(--gray-999);
		padding: 1rem 2.5rem;
		border-radius: 9999px;
		font-weight: 600;
		text-decoration: none;
		transition: transform 0.2s;
	}

	.btn-primary:hover {
		transform: translateY(-2px);
	}
</style>
