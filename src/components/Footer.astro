---
import Icon from './Icon.astro';
const currentYear = new Date().getFullYear();
---

<footer class="wrapper">
	<div class="footer-content">
		<div class="brand">
			<div class="logo">Papps</div>
			<p>Paulinho apps que resolvem problemas reais.</p>
		</div>
		
		<div class="links-groups">
			<div class="link-group">
				<h3>Navegação</h3>
				<a href="/#">Home</a>
				<a href="/#apps">Aplicativos</a>
				<a href="/#sobre">Sobre</a>
			</div>
			<div class="link-group">
				<h3>Suporte</h3>
				<a href="https://wa.me/5515981415825">WhatsApp</a>
				<a href="/privacidade.html">Privacidade</a>
			</div>
			<div class="link-group">
				<h3>Social</h3>
				<a href="https://github.com/ptcmariano">GitHub</a>
			</div>
		</div>
	</div>
	
	<div class="footer-bottom">
		<p>&copy; {currentYear} Paulinho.apps • Feito em Salto de Pirapora, SP.</p>
		<p class="transparency">
			Usamos Analytics anônimo para melhorar sua experiência. Nenhum dado sensível é coletado.
		</p>
	</div>
</footer>

<style>
	footer {
		padding: 6rem 1.5rem 3rem;
		border-top: 1px solid var(--gray-800);
		display: flex;
		flex-direction: column;
		gap: 4rem;
	}

	.footer-content {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
	}

	@media (min-width: 768px) {
		.footer-content {
			grid-template-columns: 1fr 2fr;
		}
	}

	.brand {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.logo {
		background: var(--gradient-accent);
		color: white;
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 10px;
		font-weight: 900;
	}

	.brand p {
		color: var(--gray-200);
		font-size: var(--text-md);
		max-width: 25ch;
	}

	.links-groups {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
		gap: 2rem;
	}

	.link-group {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.link-group h3 {
		color: var(--gray-0);
		font-size: var(--text-sm);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.5rem;
	}

	.link-group a {
		color: var(--gray-400);
		text-decoration: none;
		font-size: var(--text-base);
		transition: color 0.2s;
	}

	.link-group a:hover {
		color: var(--gray-0);
	}

	.footer-bottom {
		padding-top: 2rem;
		border-top: 1px solid var(--gray-800);
		display: flex;
		flex-direction: column;
		gap: 1rem;
		text-align: center;
		color: var(--gray-500);
		font-size: var(--text-sm);
	}

	@media (min-width: 768px) {
		.footer-bottom {
			flex-direction: row;
			justify-content: space-between;
			text-align: left;
		}
	}

	.transparency {
		max-width: 40ch;
	}
</style>
