---
interface Props {
	title: string;
	description: string;
	accent: string;
	features: string[];
	slug: string;
	appUrl: string;
	githubUrl: string;
}

const { title, description, accent, features, slug, appUrl, githubUrl } = Astro.props;
---

<dialog id={`modal-${slug}`} class="modal" style={`--accent: ${accent}`}>
	<div class="modal-content">
		<header>
			<div class="header-main">
				<div class="accent-dot"></div>
				<h2>{title}</h2>
			</div>
			<button class="close-modal" aria-label="Fechar">&times;</button>
		</header>
		
		<div class="body">
			<p class="description">{description}</p>
			
			<div class="features">
				<h3>Principais Funcionalidades</h3>
				<ul>
					{features.map(feature => <li>{feature}</li>)}
				</ul>
			</div>
			
			<div class="ctas">
				<a href={appUrl} target="_blank" class="btn btn-primary">Abrir App em Tela Cheia</a>
				<div class="btn-group">
					<a href={githubUrl} target="_blank" class="btn btn-secondary">Ver no GitHub</a>
					<button class="btn btn-secondary share-btn" data-title={title} data-url={appUrl}>Compartilhar</button>
				</div>
			</div>
		</div>
	</div>
</dialog>

<style>
	.modal {
		border: none;
		background: transparent;
		padding: 0;
		max-width: 600px;
		width: 90%;
		border-radius: 1.5rem;
		color: var(--gray-100);
	}

	.modal::backdrop {
		background: rgba(0, 0, 0, 0.8);
		backdrop-filter: blur(8px);
	}

	.modal-content {
		background: var(--gray-900);
		border: 1px solid var(--gray-700);
		border-radius: 1.5rem;
		box-shadow: 0 0 50px -10px var(--accent);
		overflow: hidden;
	}

	header {
		padding: 2rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		border-bottom: 1px solid var(--gray-800);
	}

	.header-main {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.accent-dot {
		width: 16px;
		height: 16px;
		background-color: var(--accent);
		border-radius: 50%;
		box-shadow: 0 0 15px var(--accent);
	}

	h2 {
		font-size: var(--text-2xl);
		margin: 0;
		color: var(--gray-0);
	}

	.close-modal {
		background: none;
		border: none;
		color: var(--gray-400);
		font-size: 2rem;
		cursor: pointer;
		line-height: 1;
		transition: color 0.2s;
	}

	.close-modal:hover {
		color: var(--gray-0);
	}

	.body {
		padding: 2rem;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.description {
		font-size: var(--text-lg);
		color: var(--gray-200);
		line-height: 1.6;
	}

	.features h3 {
		font-size: var(--text-md);
		color: var(--gray-0);
		margin-bottom: 1rem;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.features ul {
		list-style: none;
		padding: 0;
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.75rem;
	}

	@media (min-width: 600px) {
		.features ul {
			grid-template-columns: 1fr 1fr;
		}
	}

	.features li {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--gray-300);
	}

	.features li::before {
		content: '✓';
		color: var(--accent);
		font-weight: bold;
	}

	.ctas {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-top: 1rem;
	}

	.btn {
		padding: 1rem 1.5rem;
		border-radius: 0.75rem;
		font-weight: 600;
		text-align: center;
		text-decoration: none;
		transition: all 0.2s;
		font-size: var(--text-base);
		cursor: pointer;
	}

	.btn-primary {
		background: var(--accent);
		color: white;
		border: none;
	}

	.btn-primary:hover {
		filter: brightness(1.1);
		transform: translateY(-2px);
		box-shadow: 0 5px 15px var(--accent);
	}

	.btn-group {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}

	.btn-secondary {
		background: var(--gray-800);
		color: var(--gray-100);
		border: 1px solid var(--gray-700);
	}

	.btn-secondary:hover {
		background: var(--gray-700);
		border-color: var(--gray-600);
	}
</style>
