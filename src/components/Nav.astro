---
import Icon from './Icon.astro';

const textLinks: { label: string; href: string }[] = [
	{ label: 'Home', href: '/#' },
	{ label: 'Apps', href: '/#apps' },
	{ label: 'Sobre', href: '/#sobre' },
	{ label: 'Em Breve', href: '/#em-breve' },
];

const iconLinks: { label: string; href: string; icon: any }[] = [
	{ label: 'GitHub', href: 'https://github.com/ptcmariano', icon: 'github-logo' },
];

const isCurrentPage = (href: string) => {
	let pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
	if (pathname.at(0) !== '/') pathname = '/' + pathname;
	if (pathname.at(-1) !== '/') pathname += '/';
	return pathname === href || (href !== '/' && pathname.startsWith(href));
};
---

<nav>
	<div class="menu-header">
		<a href="/" class="site-title">
			<div class="logo-box">Papps</div>
			<span>Paulinho.apps</span>
		</a>
		
		<menu-button>
			<template>
				<button class="menu-button" aria-expanded="false">
					<span class="sr-only">Menu</span>
					<Icon icon="list" />
				</button>
			</template>
		</menu-button>
	</div>
	
	<div id="menu-content" hidden>
		<ul class="nav-items">
			{
				textLinks.map(({ label, href }) => (
					<li>
						<a class="link" href={href}>
							{label}
						</a>
					</li>
				))
			}
		</ul>
		<div class="menu-footer">
			<div class="socials">
				{
					iconLinks.map(({ href, icon, label }) => (
						<a href={href} class="social">
							<span class="sr-only">{label}</span>
							<Icon icon={icon} />
						</a>
					))
				}
			</div>
		</div>
	</div>
</nav>

<script>
	class MenuButton extends HTMLElement {
		constructor() {
			super();
			const template = this.querySelector('template');
			if (!template) return;
			this.appendChild(template.content.cloneNode(true));
			const btn = this.querySelector('button');
			const menu = document.getElementById('menu-content');
			if (!btn || !menu) return;

			menu.hidden = true;
			menu.classList.add('menu-content');

			const setExpanded = (expand: boolean) => {
				btn.setAttribute('aria-expanded', expand ? 'true' : 'false');
				menu.hidden = !expand;
			};

			btn.addEventListener('click', () => setExpanded(menu.hidden));

			const handleViewports = (e: MediaQueryList | MediaQueryListEvent) => {
				if (e.matches) {
					setExpanded(true);
					btn.hidden = true;
				} else {
					setExpanded(false);
					btn.hidden = false;
				}
			};
			const mediaQueries = window.matchMedia('(min-width: 50em)');
			handleViewports(mediaQueries);
			mediaQueries.addEventListener('change', handleViewports);
		}
	}
	customElements.define('menu-button', MenuButton);
</script>

<style>
	nav {
		z-index: 9999;
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		background: rgba(10, 10, 10, 0.8);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--gray-800);
		font-family: var(--font-body);
		font-weight: 500;
	}

	.menu-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1rem 1.5rem;
	}

	.site-title {
		display: flex;
		gap: 0.75rem;
		align-items: center;
		line-height: 1.1;
		color: var(--gray-0);
		text-decoration: none;
		font-weight: 700;
		font-size: var(--text-lg);
	}

	.logo-box {
		background: var(--gradient-accent);
		color: white;
		width: 32px;
		height: 32px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 8px;
		font-size: 0.8rem;
		font-weight: 900;
	}

	.menu-button {
		display: flex;
		border: 0;
		border-radius: 0.5rem;
		padding: 0.5rem;
		font-size: 1.5rem;
		color: var(--gray-300);
		background: var(--gray-800);
		cursor: pointer;
	}

	.nav-items {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		list-style: none;
		padding: 2rem;
		background-color: var(--gray-999);
	}

	.link {
		color: var(--gray-300);
		text-decoration: none;
		font-size: var(--text-md);
		transition: color 0.2s;
	}

	.link:hover {
		color: var(--gray-0);
	}

	.menu-footer {
		padding: 1.5rem 2rem;
		background-color: var(--gray-999);
		border-top: 1px solid var(--gray-800);
	}

	.socials {
		display: flex;
		gap: 1rem;
		font-size: 1.5rem;
	}

	.social {
		color: var(--gray-300);
		text-decoration: none;
		transition: color 0.2s;
	}

	.social:hover {
		color: var(--gray-0);
	}

	@media (min-width: 50em) {
		nav {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 0.75rem 5rem;
		}

		.menu-header {
			padding: 0;
		}

		.menu-content {
			display: flex !important;
			align-items: center;
			gap: 3rem;
			position: static;
			background: transparent;
		}

		.nav-items {
			flex-direction: row;
			padding: 0;
			background: transparent;
			gap: 2rem;
		}

		.link {
			font-size: var(--text-sm);
		}

		.menu-footer {
			padding: 0;
			background: transparent;
			border: 0;
		}
	}
</style>
