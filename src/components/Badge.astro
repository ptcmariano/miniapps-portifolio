---
interface Props {
	text: string;
}

const { text } = Astro.props;
---

<span class="badge">
	{text}
</span>

<style>
	.badge {
		background: var(--gray-800);
		color: var(--gray-200);
		padding: 0.25rem 0.75rem;
		border-radius: 9999px;
		font-size: var(--text-sm);
		font-weight: 500;
		border: 1px solid var(--gray-700);
		white-space: nowrap;
	}
</style>
